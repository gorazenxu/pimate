{
  "name": "pisidian",
  "version": "1.0.9",
  "description": "Pisidian embeds Pi Coding Agent into Obsidian",
  "main": "main.js",
  "scripts": {
    "dev": "node esbuild.config.mjs",
    "build": "tsc -noEmit -skipLibCheck && node esbuild.config.mjs production",
    "version": "node version-bump.mjs && git add manifest.json versions.json"
  },
  "keywords": [
    "obsidian-plugin",
    "pisidian",
    "ai",
    "coding-agent"
  ],
  "license": "GPL-3.0-only",
  "devDependencies": {
    "@types/node": "^20.0.0",
    "builtin-modules": "^4.0.0",
    "esbuild": "^0.28.0",
    "obsidian": "^1.5.0",
    "tslib": "^2.6.0",
    "typescript": "^5.4.0"
  }
}
